{
    "name": "monsoon/cms",
    "description": "Monsoon CMS",
    "type": "project",
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Monsoon\\Kernel\\": "kernel/src/",
            "Monsoon\\Modules\\": "modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Monsoon\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    }
}
